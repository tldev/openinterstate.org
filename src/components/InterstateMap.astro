---
import mapData from "../data/interstate-map.json";
---

<div class="map-wrap">
  <svg
    viewBox={mapData.viewBox}
    xmlns="http://www.w3.org/2000/svg"
    class="interstate-map"
    aria-label="Map of US primary interstates"
    role="img"
  >
    <g data-states
      fill="none"
      stroke="#e5e5e5"
      stroke-width="0.75"
      stroke-linejoin="round"
      opacity="0.7"
    >
      {mapData.states.map((s) => <path d={s.d} data-state={s.name} />)}
    </g>
    <g fill="none">
      {mapData.interstates.map((r, i) => (
        <g data-route data-idx={i}>
          <path
            d={r.d}
            stroke="transparent"
            stroke-width="8"
            stroke-linecap="round"
            fill="none"
          />
          <path
            d={r.d}
            stroke="#737373"
            stroke-width="1.3"
            stroke-linecap="round"
            stroke-linejoin="round"
            opacity="0.3"
          />
          <path
            d={r.d}
            stroke="#171717"
            stroke-width="1.3"
            stroke-linecap="round"
            stroke-linejoin="round"
            opacity="0"
            style="pointer-events:none"
          />
          <text
            x={r.lx}
            y={r.ly}
            fill="#737373"
            opacity="0.45"
            font-size="6"
            text-anchor="middle"
            dominant-baseline="central"
            style="pointer-events:none"
          >{r.name}</text>
        </g>
      ))}
    </g>
  </svg>
  <div class="map-card" aria-hidden="true">
    <div class="map-card-header">
      <span class="map-card-name"></span>
      <span class="map-card-length"></span>
    </div>
    <div class="map-card-body">
      <div class="map-card-row map-card-exit-a">
        <span class="map-card-label"></span>
        <span class="map-card-value"></span>
      </div>
      <div class="map-card-row map-card-exit-b">
        <span class="map-card-label"></span>
        <span class="map-card-value"></span>
      </div>
    </div>
    <div class="map-card-states"></div>
  </div>
</div>

<script define:vars={{ routeMeta: mapData.interstates.map(r => ({ name: r.name, lengthMi: r.lengthMi, exits: r.exits })) }}>
  const svg = document.querySelector('.interstate-map');
  const card = document.querySelector('.map-card');

  if (svg && card) {
    const nameEl = card.querySelector('.map-card-name');
    const lengthEl = card.querySelector('.map-card-length');
    const exitA = card.querySelector('.map-card-exit-a');
    const exitB = card.querySelector('.map-card-exit-b');
    const statesEl = card.querySelector('.map-card-states');

    const stateEls = svg.querySelectorAll('[data-states] > path');
    const stateCache = new WeakMap();

    function getRouteStates(hlPath, L) {
      if (stateCache.has(hlPath)) return stateCache.get(hlPath);
      const names = new Set();
      const samples = 60;
      for (let i = 0; i <= samples; i++) {
        const pt = hlPath.getPointAtLength((i / samples) * L);
        for (const sp of stateEls) {
          const name = sp.getAttribute('data-state');
          if (!names.has(name) && sp.isPointInFill({ x: pt.x, y: pt.y })) {
            names.add(name);
          }
        }
      }
      const sorted = [...names].sort();
      stateCache.set(hlPath, sorted);
      return sorted;
    }

    function showCard(idx, stateNames) {
      const meta = routeMeta[idx];
      if (!meta) return;

      nameEl.textContent = meta.name;
      lengthEl.textContent = meta.lengthMi.toLocaleString() + ' mi';

      const dirs = Object.entries(meta.exits).sort(([a], [b]) => a.localeCompare(b));
      [exitA, exitB].forEach((row, i) => {
        if (dirs[i]) {
          row.querySelector('.map-card-label').textContent = dirs[i][0] + ' Exits';
          row.querySelector('.map-card-value').textContent = dirs[i][1].toLocaleString();
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });

      statesEl.textContent = stateNames.join(', ');
      card.classList.add('visible');
    }

    function hideCard() {
      card.classList.remove('visible');
    }

    document.querySelectorAll('[data-route]').forEach(g => {
      const paths = g.querySelectorAll('path');
      const hl = paths[2];
      if (!hl) return;

      const idx = parseInt(g.getAttribute('data-idx'), 10);
      const L = hl.getTotalLength();
      hl.style.strokeDasharray = `0 ${L}`;
      hl.style.strokeDashoffset = '0';

      let raf = null;
      let fadeTimer = null;

      g.addEventListener('mouseenter', e => {
        if (raf) cancelAnimationFrame(raf);
        if (fadeTimer) clearTimeout(fadeTimer);

        const ctm = svg.getScreenCTM();
        if (!ctm) return;
        const pt = svg.createSVGPoint();
        pt.x = e.clientX;
        pt.y = e.clientY;
        const sp = pt.matrixTransform(ctm.inverse());

        const P = nearest(hl, sp, L);
        const maxW = 2 * Math.max(P, L - P);
        const dur = 1200;
        const t0 = performance.now();

        showCard(idx, getRouteStates(hl, L));

        hl.style.transition = 'none';
        hl.style.opacity = '0.6';

        (function tick(now) {
          const p = Math.min(1, (now - t0) / dur);
          const ease = 1 - (1 - p) ** 3;
          const w = ease * maxW;
          const s = Math.max(0, P - w / 2);
          const end = Math.min(L, P + w / 2);
          hl.style.strokeDasharray = `${end - s} ${L}`;
          hl.style.strokeDashoffset = `${-s}`;
          if (p < 1) raf = requestAnimationFrame(tick);
        })(t0);
      });

      g.addEventListener('mouseleave', () => {
        if (raf) cancelAnimationFrame(raf);
        hl.style.transition = 'opacity 0.2s';
        hl.style.opacity = '0';
        fadeTimer = setTimeout(() => {
          hl.style.strokeDasharray = `0 ${L}`;
        }, 200);
        hideCard();
      });
    });
  }

  function nearest(path, pt, L) {
    let best = 0, bestD = Infinity;
    for (let i = 0; i <= 40; i++) {
      const len = (i / 40) * L;
      const p = path.getPointAtLength(len);
      const d = (p.x - pt.x) ** 2 + (p.y - pt.y) ** 2;
      if (d < bestD) { bestD = d; best = len; }
    }
    const step = L / 40;
    const lo = Math.max(0, best - step);
    const hi = Math.min(L, best + step);
    for (let i = 0; i <= 10; i++) {
      const len = lo + (i / 10) * (hi - lo);
      const p = path.getPointAtLength(len);
      const d = (p.x - pt.x) ** 2 + (p.y - pt.y) ** 2;
      if (d < bestD) { bestD = d; best = len; }
    }
    return best;
  }
</script>

<style is:global>
  .map-wrap {
    margin: 0.5rem -3rem 2rem;
    position: relative;
  }

  .interstate-map {
    width: 100%;
    height: auto;
    display: block;
  }

  [data-route] text {
    font-family: var(--font);
    transition: opacity 0.2s, fill 0.2s;
  }

  [data-route]:hover text {
    opacity: 1;
    fill: #171717;
  }

  .map-card {
    position: absolute;
    top: 50%;
    right: -7rem;
    transform: translateY(-50%);
    width: 11rem;
    font-family: var(--font);
    font-size: 0.7rem;
    line-height: 1.4;
    color: var(--muted);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    opacity: 0;
    transition: opacity 0.15s;
    pointer-events: none;
  }

  .map-card.visible {
    opacity: 1;
  }

  .map-card-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.5rem 0.625rem;
    border-bottom: 1px solid var(--border);
  }

  .map-card-name {
    color: var(--text);
    font-weight: 700;
    font-size: 0.8rem;
  }

  .map-card-length {
    font-variant-numeric: tabular-nums;
  }

  .map-card-body {
    padding: 0.375rem 0.625rem;
    border-bottom: 1px solid var(--border);
  }

  .map-card-row {
    display: flex;
    justify-content: space-between;
    padding: 0.125rem 0;
    font-variant-numeric: tabular-nums;
  }

  .map-card-states {
    padding: 0.375rem 0.625rem;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .map-wrap {
      margin-left: -1rem;
      margin-right: -1rem;
    }

    [data-route] text {
      display: none;
    }

    .map-card {
      display: none;
    }
  }
</style>
