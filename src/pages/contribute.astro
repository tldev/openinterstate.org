---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contribute | OpenInterstate">
  <section class="page-intro">
    <p class="kicker">Contribute</p>
    <h1>Help shape the public contract early.</h1>
    <p class="lead">
      The best early contributions are naming review, schema review, release-shape review,
      examples, and documentation clarity.
    </p>
  </section>

  <section class="section">
    <div class="card-grid">
      <article class="card">
        <h3>Main repo</h3>
        <p><a href="https://github.com/tldev/openinterstate">github.com/tldev/openinterstate</a></p>
      </article>
      <article class="card">
        <h3>Site repo</h3>
        <p><a href="https://github.com/tldev/openinterstate.org">github.com/tldev/openinterstate.org</a></p>
      </article>
      <article class="card">
        <h3>Current focus</h3>
        <p>Lock names, publish the data contract, and ship the first release.</p>
      </article>
    </div>
  </section>
</BaseLayout>
