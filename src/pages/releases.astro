---
import BaseLayout from "../layouts/BaseLayout.astro";

const release = {
  tag: "release-2026-03-14-gha-12",
  archiveUrl:
    "https://github.com/tldev/openinterstate/releases/download/release-2026-03-14-gha-12/openinterstate-release-2026-03-14-gha-12.tar.gz",
  manifestUrl:
    "https://github.com/tldev/openinterstate/releases/download/release-2026-03-14-gha-12/manifest.json",
  sourceLineageUrl:
    "https://github.com/tldev/openinterstate/releases/download/release-2026-03-14-gha-12/source_lineage.json",
  checksumsUrl:
    "https://github.com/tldev/openinterstate/releases/download/release-2026-03-14-gha-12/checksums.txt",
  githubUrl:
    "https://github.com/tldev/openinterstate/releases/tag/release-2026-03-14-gha-12",
};
---

<BaseLayout title="Releases — OpenInterstate">
  <section>
    <h1>Releases</h1>
    <p>Dated, checksummed, with published lineage.</p>
  </section>

  <section>
    <h2>{release.tag}</h2>
    <p>
      277 corridors, 39,314 exits, 93,189 places, 277 reference routes.
      Built from the raw U.S. OSM PBF with standalone OpenInterstate tooling.
    </p>

    <pre><code>curl -LO \
  {release.archiveUrl}</code></pre>

    <h3>Artifacts</h3>
    <ul class="links">
      <li><a href={release.archiveUrl}>Release archive (.tar.gz)</a></li>
      <li><a href={release.manifestUrl}>manifest.json</a></li>
      <li><a href={release.sourceLineageUrl}>source_lineage.json</a></li>
      <li><a href={release.checksumsUrl}>checksums.txt</a></li>
      <li><a href={release.githubUrl}>GitHub release page</a></li>
    </ul>
  </section>

  <section>
    <h2>Format</h2>
    <p>
      CSV tables + GPX reference routes + GeoJSON examples. V1 favors usability
      over stricter packaging.
    </p>
  </section>
</BaseLayout>
