---
import BaseLayout from "../layouts/BaseLayout.astro";
import { release, reachabilityRelease } from "../data/releases";
---

<BaseLayout title="Releases — OpenInterstate">
  <section>
    <h1>Releases</h1>
    <p class="lead">Dated, checksummed, with published lineage.</p>
  </section>

  <section>
    <h2>{release.tag}</h2>
    <p>
      647 corridors, 96,366 exits, 109,647 places, 468,361 exit-place links, 263 reference routes.
      Built from the raw U.S. OSM PBF with standalone OpenInterstate tooling.
    </p>

    <pre><code>curl -LO \
  {release.archiveUrl}</code></pre>

    <h3>Artifacts</h3>
    <ul class="links">
      <li><a href={release.archiveUrl}>Release archive (.tar.gz)</a></li>
      <li><a href={release.manifestUrl}>manifest.json</a></li>
      <li><a href={release.sourceLineageUrl}>source_lineage.json</a></li>
      <li><a href={release.checksumsUrl}>checksums.txt</a></li>
      <li><a href={release.githubUrl}>GitHub release page</a></li>
    </ul>
  </section>

  <section>
    <h2>Reachability scores</h2>
    <p>
      Reachability scores are published separately from
      <a href="https://github.com/tldev/openinterstate-reachability">openinterstate-reachability</a>.
    </p>
    <p>
      Latest: <a href={reachabilityRelease.githubUrl}>{reachabilityRelease.tag}</a>
    </p>
  </section>

  <section>
    <h2>Format</h2>
    <p>
      CSV tables + GPX reference routes + GeoJSON examples. V1 favors usability
      over stricter packaging.
    </p>
  </section>
</BaseLayout>
