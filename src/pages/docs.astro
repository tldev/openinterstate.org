---
import BaseLayout from "../layouts/BaseLayout.astro";

const docs = [
  ["Project charter", "Mission, scope, and Pike boundary"],
  ["Naming glossary", "Preferred public nouns and what to avoid"],
  ["Data contract", "The current public release surface"],
  ["Release format", "Manifest and file-layout expectations"],
  ["Release build guide", "How v1 is exported from Postgres"],
  ["Licensing and attribution", "Working assumptions and launch requirements"],
];
---

<BaseLayout title="Docs — OpenInterstate">
  <section>
    <h1>Documentation</h1>
    <p>
      Docs live in the main repository. The public contract matters more than
      the stack choice.
    </p>
  </section>

  <section>
    <table>
      <thead>
        <tr>
          <th>Document</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        {docs.map(([title, desc]) => (
          <tr>
            <td>{title}</td>
            <td>{desc}</td>
          </tr>
        ))}
      </tbody>
    </table>
    <p>
      <a href="https://github.com/tldev/openinterstate/tree/main/docs">Browse all docs on GitHub →</a>
    </p>
  </section>
</BaseLayout>
