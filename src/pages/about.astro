---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | OpenInterstate">
  <section class="page-intro">
    <p class="kicker">About</p>
    <h1>An upstream project, not a single-app feature dump.</h1>
    <p class="lead">
      OpenInterstate is meant to be useful even if Pike did not exist. Pike is one downstream
      consumer, not the definition of the public contract.
    </p>
  </section>

  <section class="section">
    <div class="band">
      <p class="kicker">Principles</p>
      <ul class="list-clean">
        <li>Use neutral public names.</li>
        <li>Publish reproducible releases.</li>
        <li>Keep lineage and attribution explicit.</li>
        <li>Optimize for developers and GIS users first.</li>
      </ul>
    </div>
  </section>
</BaseLayout>
