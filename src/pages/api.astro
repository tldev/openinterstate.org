---
import BaseLayout from "../layouts/BaseLayout.astro";

const endpoints = [
  ["GET", "/v1/releases"],
  ["GET", "/v1/releases/latest"],
  ["GET", "/v1/corridors"],
  ["GET", "/v1/corridors/:corridor_id"],
  ["GET", "/v1/exits/:exit_id"],
  ["GET", "/v1/exits/:exit_id/places"],
  ["GET", "/v1/reference-routes"],
  ["GET", "/v1/reference-routes/:id"],
];
---

<BaseLayout title="API — OpenInterstate">
  <section>
    <h1>API</h1>
    <p class="lead">
      Read-only lookup and discovery over release-backed data. Static releases
      come first; the API follows the published contract.
    </p>
  </section>

  <section>
    <h2>Endpoints</h2>
    <table>
      <thead>
        <tr>
          <th>Method</th>
          <th>Path</th>
        </tr>
      </thead>
      <tbody>
        {endpoints.map(([method, path]) => (
          <tr>
            <td>{method}</td>
            <td>{path}</td>
          </tr>
        ))}
      </tbody>
    </table>
    <p>
      Draft spec:
      <a href="https://github.com/tldev/openinterstate/blob/main/api/openapi.yaml">api/openapi.yaml</a>
    </p>
  </section>
</BaseLayout>
