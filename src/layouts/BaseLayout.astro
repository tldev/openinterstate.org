---
const {
  title = "OpenInterstate",
  description = "Open interstate system data for the United States.",
} = Astro.props;
import "../styles/global.css";

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- open graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="OpenInterstate" />

    <!-- twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- google analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GVQN1YLG5B"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GVQN1YLG5B');
    </script>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="shell">
      <header class="header">
        <a class="brand" href="/">openinterstate</a>
        <nav>
          <a href="/data">data</a>
          <a href="/api">api</a>
          <a href="/docs">docs</a>
          <a href="/releases">releases</a>
          <a href="/about">about</a>
          <a href="/contribute">contribute</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="footer">
        <p><a href="https://github.com/tldev/openinterstate">github.com/tldev/openinterstate</a></p>
        <p>Data derived from <a href="https://www.openstreetmap.org/">OpenStreetMap</a>. ODbL.</p>
      </footer>
    </div>
  </body>
</html>
